# ─── Supabase (REQUIRED) ───────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── App (REQUIRED) ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://your-domain.com

# ─── Auth (REQUIRED) ──────────────────────────────────────────────────────────
SUPER_ADMIN_EMAILS=admin@example.com

# ─── Payments: Stripe (REQUIRED for card payments) ────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Payments: Recurrente (REQUIRED for Guatemala card payments) ──────────────
RECURRENTE_API_KEY=your_recurrente_api_key
RECURRENTE_WEBHOOK_SECRET=your_recurrente_webhook_secret
# RECURRENTE_API_URL=https://app.recurrente.com/api  # optional override

# ─── Email: Resend (REQUIRED for booking confirmations) ──────────────────────
RESEND_API_KEY=re_...

# ─── AI: OpenRouter (OPTIONAL — for AI review responses) ─────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ─── Google OAuth (OPTIONAL — for Google Business reviews) ────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# ─── SerpAPI (OPTIONAL — for review discovery) ────────────────────────────────
SERPAPI_API_KEY=your_serpapi_key

# ─── Encryption (REQUIRED if using Google OAuth) ─────────────────────────────
TOKEN_ENCRYPTION_KEY=32_byte_hex_key

# ─── Cron Auth (RECOMMENDED for Vercel cron security) ────────────────────────
CRON_SECRET=your_cron_secret
